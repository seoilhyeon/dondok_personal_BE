# MySQL
MYSQL_DATABASE=dondok
MYSQL_USER=dondok
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3306
MYSQL_URL=jdbc:mysql://localhost:3306/dondok?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
DDL_AUTO=validate

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=3s

# JWT
JWT_ISSUER=dondok
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_SECRET=

# AWS / Spring Cloud AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Keep empty when object keys are stored as mission/*, profile/*, crew/*.
AWS_S3_BASE_PREFIX=
# Create this object in the bucket before enabling S3 readiness.
# Final key is <AWS_S3_BASE_PREFIX>/<AWS_S3_HEALTHCHECK_KEY> when prefix is set.
AWS_S3_HEALTHCHECK_KEY=healthcheck/s3-readiness
AWS_S3_HEALTHCHECK_TIMEOUT=3s

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Cookie
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=
