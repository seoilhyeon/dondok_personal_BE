# Spring profile
SPRING_PROFILES_ACTIVE=local

# MySQL
MYSQL_DATABASE=dondok
MYSQL_USER=dondok
MYSQL_PASSWORD=dondok
MYSQL_ROOT_PASSWORD=root
MYSQL_PORT=3306
MYSQL_URL=jdbc:mysql://localhost:3306/dondok?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
DDL_AUTO=update

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT=3s

# JWT
JWT_ISSUER=dondok
JWT_ACCESS_TOKEN_EXPIRATION=30m
JWT_REFRESH_TOKEN_EXPIRATION=7d
JWT_SECRET=change-me-to-a-long-random-secret

# AWS / Spring Cloud AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Firebase Cloud Messaging
FIREBASE_CREDENTIALS_PATH=
