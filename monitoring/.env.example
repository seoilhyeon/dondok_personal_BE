GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me

# Docker network shared with the blue/green API containers.
APP_NETWORK=dondok-network

# Keep these loopback-only by default. Use 0.0.0.0:3000 only with a restricted security group.
GRAFANA_PORT_BIND=127.0.0.1:3000
PROMETHEUS_PORT_BIND=127.0.0.1:9090
